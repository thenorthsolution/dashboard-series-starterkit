# OAuth2 credentials — used by apps/web (NextAuth)
DISCORD_CLIENT_ID="your-client-id-here"
DISCORD_CLIENT_SECRET="your-client-secret-here"

# -----------------------------------------------------------------------------
# NEXTAUTH v5  (apps/web)
# Generate secret: openssl rand -base64 32
# -----------------------------------------------------------------------------
AUTH_SECRET="your-nextauth-secret-here"

# The canonical URL of the Next.js app
# Local:      http://localhost:3000
# Production: https://your-domain.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# The URL Next.js uses to reach the sidecar
# Local:      http://localhost:4000
# Production: internal Railway service URL
SIDECAR_URL="http://localhost:4000"

# Shared secret used to authenticate requests from Next.js → sidecar
# Generate: openssl rand -base64 32
SIDECAR_SECRET="your-sidecar-secret-here"

# -----------------------------------------------------------------------------
# NEXT.JS APP  (apps/web)
# -----------------------------------------------------------------------------
# Public app URL (used in og:url, redirects, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
