# MAKE SURE TO FILL IN THIS .ENV AND THE ONE IN apps/web

# -----------------------------------------------------------------------------
# DATABASE (Neon.tech PostgreSQL)
# Get from: https://console.neon.tech → your project → Connection Details
#
# Prisma v7 routes the two URLs differently from v6:
#
#   DATABASE_URL  — Neon POOLED connection string (PgBouncer).
#                   Used at RUNTIME by the PrismaNeon adapter in
#                   packages/database/src/index.ts.
#                   Toggle "Connection pooling: ON" in Neon to get this URL.
#
#   DIRECT_URL    — Neon DIRECT (non-pooled) connection string.
#                   Used by the Prisma CLI (prisma migrate / db push) via
#                   prisma.config.ts → datasource.url.
#                   Migrations need a direct connection; PgBouncer blocks DDL.
#                   Toggle "Connection pooling: OFF" in Neon to get this URL.
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@host-pooler.region.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:password@host.region.aws.neon.tech/dbname?sslmode=require"


# -----------------------------------------------------------------------------
# DISCORD APPLICATION
# Get from: https://discord.com/developers/applications → your app
# -----------------------------------------------------------------------------
# Bot token — used by apps/bot
DISCORD_TOKEN="your-bot-token-here"

# The bot's numeric user ID (right-click bot in Discord → Copy User ID)
DISCORD_BOT_ID="your-bot-user-id-here"

# Guild ID used for slash command registration during development
# (guild-scoped commands update instantly; global commands take ~1 hour)
DISCORD_DEV_GUILD_ID="your-dev-guild-id-here"

# -----------------------------------------------------------------------------
# SIDECAR (packages/adapter / apps/bot Express server)
# The sidecar is the HTTP bridge between Next.js and the Discord.js bot.
# -----------------------------------------------------------------------------
# Port the Express sidecar listens on
SIDECAR_PORT="4000"


